# ════════════════════════════════════════════════════════════════════
#  多幣流動性掃蕩機器人 v2  —  環境變數設定
# ════════════════════════════════════════════════════════════════════

# ── Binance API ───────────────────────────────────────────────────────
BINANCE_API_KEY=你的API_KEY
BINANCE_SECRET_KEY=你的SECRET_KEY

# 正式交易設 false，測試用 true
BINANCE_TESTNET=false

# ── 幣對（10個，逗號分隔，不要有空格）────────────────────────────
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,TONUSDT,AVAXUSDT,LINKUSDT

# ── 倉位設定 ─────────────────────────────────────────────────────────
# 每倉固定 50 USDT，本金增加後在 Railway 直接改這個數字
POSITION_SIZE_USDT=50
LEVERAGE=20

# 最大同時持倉數（10個幣同時掃，最多幾個同時開倉）
MAX_CONCURRENT_POSITIONS=3

# ── 風控 ─────────────────────────────────────────────────────────────
# 每日虧損超過此值自動停止開新倉（UTC 0:00 重置）
DAILY_LOSS_LIMIT_USDT=150
# 單筆最長持倉時間（秒），超時強平
MAX_HOLD_SECONDS=600
# 止損緩衝（0.001 = 掃蕩高點/低點外 0.1%）
STOP_LOSS_BUFFER_PCT=0.001

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=你的BOT_TOKEN
TELEGRAM_CHAT_ID=你的CHAT_ID

# ── 進階參數（不熟悉不要動）─────────────────────────────────────────
LIQUIDITY_SCAN_PCT=0.02
LIQUIDITY_LAYERS=3
WALL_LOCAL_RATIO=4.0
ABSORPTION_WINDOW_SEC=300
EXHAUSTION_WINDOW_SEC=60
ABSORPTION_VOLUME_MULTIPLIER=1.8
EXHAUSTION_VOLUME_RATIO=0.55
SWEEP_PRICE_MULTIPLIER=5.0
SWEEP_VOLUME_MULTIPLIER=10.0
APEX_DELTA_CONSECUTIVE=5
APEX_MIN_HIT_RATIO=0.8
